    "alert_parking_expired" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انتهى وقت عداد الموقف أو على وشك الانتهاء. هل تريد أن نوجهك إلى سيارتك؟"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Parkuhrzeit ist abgelaufen oder läuft bald ab. Sollen wir dich zu deinem Auto führen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The parking meter time has expired or is about to expire. Do you want us to guide you to your car?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El tiempo del parquímetro ha expirado o está a punto de hacerlo. ¿Quieres que te guiemos hasta tu coche?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le temps du parcmètre a expiré ou va bientôt expirer. Voulez-vous que nous vous guidions vers votre voiture ?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tempo del parcometro è scaduto o sta per scadere. Vuoi che ti guidiamo alla tua auto?"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O tempo do parquímetro expirou ou está prestes a expirar. Quer que o guiemos até seu carro?"
          }
        }
      }
    },
